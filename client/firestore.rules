rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function hasRole(roleName) { return isSignedIn() && request.auth.token.role == roleName; }
    function isNutritionist() { return isSignedIn() && request.auth.token.role in ['nutritionist', 'coach']; }
    function isPT() { return isSignedIn() && request.auth.token.role in ['personal_trainer', 'coach']; }
    
    function isAssignedNutri(userData) { return isNutritionist() && (userData.parent_id == request.auth.uid || userData.nutritionist_id == request.auth.uid || userData.created_by == request.auth.uid); }
    function isAssignedPT(userData) { return isPT() && (userData.parent_id == request.auth.uid || userData.pt_id == request.auth.uid || userData.created_by == request.auth.uid); }
    function isAssignedProfessional(userData) { return isAssignedNutri(userData) || isAssignedPT(userData); }

    // Helper per controllare quali campi vengono modificati
    function affectsOnly(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    // [SECURITY FIX] Config globale leggibile solo da utenti autenticati
    match /config/global {
      allow read: if isSignedIn();
      allow write: if hasRole('admin');
    }

    // [SECURITY FIX] App config leggibile da autenticati, modificabile solo da admin
    match /app_config/{document} {
      allow read: if isSignedIn();
      allow write: if hasRole('admin');
    }

    match /users/{userId} {
      allow read: if isOwner(userId) ||
                  hasRole('admin') ||
                  isAssignedProfessional(resource.data) ||
                  (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.parent_id == userId);

      // [SECURITY FIX] Create: Solo il proprio profilo con validazione campi
      allow create: if isOwner(userId) &&
                       request.resource.data.keys().hasAll(['uid', 'email', 'role']) &&
                       request.resource.data.uid == userId &&
                       request.resource.data.role in ['independent', 'user'];

      // UPDATE: Invariato (più campi aggiunti per XP + last_seen heartbeat)
      allow update: if (isOwner(userId) &&
                        request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['first_name', 'last_name', 'last_login', 'last_seen', 'is_active', 'unlocked_badges', 'xp_total', 'xp_today', 'xp_today_date'])) ||
                       hasRole('admin') ||
                       isAssignedProfessional(resource.data);

      // DELETE: Invariato
      allow delete: if hasRole('admin') ||
                       isAssignedProfessional(resource.data);

      // [MODIFICATO] DIETS: Ora l'utente PUÒ scrivere (Create/Update) le sue diete
      match /diets/{dietId} {
        allow read: if isOwner(userId) ||
                   isAssignedNutri(get(/databases/$(database)/documents/users/$(userId)).data);

        // QUI ERA IL BLOCCO: Aggiunto "isOwner(userId)" per permettere il salvataggio app
        allow write: if isOwner(userId) ||
                     hasRole('admin') ||
                     isAssignedNutri(get(/databases/$(database)/documents/users/$(userId)).data);
      }

      // Manteniamo history per retrocompatibilità o se usato altrove
      match /history/{docId} {
        allow read: if isOwner(userId) ||
                   isAssignedNutri(get(/databases/$(database)/documents/users/$(userId)).data);

        allow create: if isOwner(userId) ||
                      hasRole('admin') ||
                      isAssignedNutri(get(/databases/$(database)/documents/users/$(userId)).data);

        allow update, delete: if hasRole('admin') ||
                              isAssignedNutri(get(/databases/$(database)/documents/users/$(userId)).data);
      }

      match /parser_history/{docId} {
        allow read, write: if hasRole('admin');
      }

      // --- TRACKING COLLECTIONS ---
      match /weight_history/{docId} {
        allow read: if isOwner(userId) ||
                   isAssignedProfessional(get(/databases/$(database)/documents/users/$(userId)).data);
        allow write: if isOwner(userId);
      }

      match /daily_stats/{docId} {
        allow read: if isOwner(userId) ||
                   isAssignedProfessional(get(/databases/$(database)/documents/users/$(userId)).data);
        allow write: if isOwner(userId);
      }

      match /goals/{docId} {
        allow read: if isOwner(userId) ||
                   isAssignedProfessional(get(/databases/$(database)/documents/users/$(userId)).data);
        allow write: if isOwner(userId);
      }

      match /meal_notes/{docId} {
        allow read: if isOwner(userId) ||
                   isAssignedNutri(get(/databases/$(database)/documents/users/$(userId)).data);
        allow write: if isOwner(userId);
      }

      match /xp_history/{docId} {
        allow read: if isOwner(userId) ||
                   isAssignedProfessional(get(/databases/$(database)/documents/users/$(userId)).data);
        allow write: if isOwner(userId);
      }

      // [SECURITY] Note interne visibili/modificabili solo da admin o dal professionista
      // corrente (parent_id/pt_id). I client non possono accedere alle proprie note interne.
      match /internal_notes/{noteId} {
        allow read, write: if hasRole('admin') ||
                           isAssignedProfessional(get(/databases/$(database)/documents/users/$(userId)).data);
      }
    }

    match /diet_history/{docId} {
      // [SECURITY FIX] Il nutrizionista può leggere solo se è ANCORA assegnato al client
      // (parent_id/nutritionist_id attuale). Un ex-nutrizionista non vede più lo storico.
      allow read: if isOwner(resource.data.userId) ||
                  hasRole('admin') ||
                  (resource.data.uploadedBy == request.auth.uid &&
                   isAssignedNutri(get(/databases/$(database)/documents/users/$(resource.data.userId)).data));
      allow create: if isNutritionist() || hasRole('admin');
      allow delete: if hasRole('admin');
    }

    // ═══════════════════════════════════════════════════════════════════════
    // CHAT RULES - Participant-based access
    // ═══════════════════════════════════════════════════════════════════════
    match /chats/{chatId} {
      // Helper: check if user is a participant of this chat
      function isParticipant() {
        return resource.data.participants.clientId == request.auth.uid ||
               resource.data.participants.nutritionistId == request.auth.uid;
      }

      // Helper for create (document doesn't exist yet, use request.resource)
      function isParticipantOnCreate() {
        return request.resource.data.participants.clientId == request.auth.uid ||
               request.resource.data.participants.nutritionistId == request.auth.uid;
      }

      // Read: participant or admin
      allow read: if isSignedIn() && (
        isParticipant() ||
        hasRole('admin')
      );

      // Create: participant or admin
      allow create: if isSignedIn() && (
        isParticipantOnCreate() ||
        hasRole('admin')
      );

      // Update: participant or admin
      allow update: if isSignedIn() && (
        isParticipant() ||
        hasRole('admin')
      );

      // No chat deletion
      allow delete: if hasRole('admin');

      // Messages subcollection
      match /messages/{messageId} {
        // Helper: check if user is a participant of parent chat
        function isChatParticipant() {
          let chat = get(/databases/$(database)/documents/chats/$(chatId)).data;
          return chat.participants.clientId == request.auth.uid ||
                 chat.participants.nutritionistId == request.auth.uid;
        }

        // Read: any chat participant or admin
        allow read: if isSignedIn() && (
          isChatParticipant() ||
          hasRole('admin')
        );

        // Create: must be a participant AND senderId must match auth uid
        allow create: if isSignedIn() && (
          request.resource.data.senderId == request.auth.uid &&
          (isChatParticipant() || hasRole('admin'))
        );

        // Update: only allow updating 'read' field by participants
        allow update: if isSignedIn() &&
                      affectsOnly(['read']) &&
                      (isChatParticipant() || hasRole('admin'));

        // No message deletion
        allow delete: if false;
      }
    }

    match /access_logs/{logId} {
       allow read: if hasRole('admin');
       allow create, update, delete: if false;
    }

    // [SECURITY] Cache AI — solo Admin SDK (backend). Client non hanno accesso.
    match /gemini_cache/{cacheId} {
      allow read, write: if false;
    }

    // [SECURITY] Log consensi GDPR — solo backend via Admin SDK.
    // L'admin può leggere via API (non direttamente da Firestore client).
    match /consent_logs/{logId} {
      allow read, write: if false;
    }

    match /{document=**} { allow read, write: if false; }
  }
}
